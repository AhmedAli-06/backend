# Local Development Environment Configuration
# Copy this file to .env.local for local overrides (which are gitignored)
# This file uses local Docker defaults

# App
APP_NAME=ContextShield
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# Database (Local Docker - uses docker-compose.yml settings)
DATABASE_URL=postgresql+asyncpg://cs_admin:cs_dev_password_2025@localhost:5432/contextshield
DATABASE_ECHO=false

# Redis (Local Docker)
REDIS_URL=redis://localhost:6379/0

# JWT (Dev secret - change for production)
JWT_SECRET_KEY=contextshield-dev-secret-key-2025
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS (Local development URLs)
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Audit (Dev HMAC)
HMAC_SECRET=contextshield-dev-hmac-secret

# Alerting (Leave empty for local dev)
RESEND_API_KEY=
ALERT_EMAIL=

# ML Models
MODEL_DIR=ml/models