# Context-Shield Environment Configuration Template
# Copy this file to .env for local development and update with your values
# IMPORTANT: Never commit .env files with real values to git

# ============================================
# APP CONFIGURATION
# ============================================

# Application name
APP_NAME=ContextShield

# Application version
APP_VERSION=0.1.0

# Debug mode - set to false in staging/production
DEBUG=true

# Environment: development, staging, or production
ENVIRONMENT=development

# ============================================
# DATABASE CONFIGURATION
# ============================================

# PostgreSQL connection string (Supabase or local)
# Format: postgresql+asyncpg://user:password@host:port/database
# For local Docker: postgresql+asyncpg://cs_admin:cs_dev_password_2025@localhost:5432/contextshield
DATABASE_URL=postgresql+asyncpg://user:password@host:port/database

# Enable SQL query logging (true/false)
DATABASE_ECHO=false

# ============================================
# REDIS CONFIGURATION
# ============================================

# Redis connection string
# Format: redis://host:port/db_number
# For local: redis://localhost:6379/0
# For Upstash: redis://xxx.upstash.io:6379/db_number
REDIS_URL=redis://host:port/0

# ============================================
# JWT AUTHENTICATION
# ============================================

# Secret key for JWT token signing (minimum 32 characters)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-secret-key-min-32-chars

# JWT algorithm (HS256, HS384, HS512)
JWT_ALGORITHM=HS256

# Access token expiration in minutes (480 = 8 hours)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ============================================
# CORS (Cross-Origin Resource Sharing)
# ============================================

# Allowed origins for CORS (comma-separated list)
# Format: ["http://localhost:5173","http://localhost:3000"]
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ============================================
# AUDIT LOGGING
# ============================================

# HMAC secret for audit log integrity verification (minimum 32 characters)
HMAC_SECRET=your-hmac-secret-min-32-chars

# ============================================
# EMAIL ALERTING (Resend)
# ============================================

# Resend API key for transactional email
# Get your API key from https://resend.com
RESEND_API_KEY=re_your_resend_api_key

# Alert email recipient
ALERT_EMAIL=alerts@yoursite.com

# ============================================
# MACHINE LEARNING MODELS
# ============================================

# Directory for ML model files
MODEL_DIR=ml/models